# Copy to .env.local

# Real AWS DynamoDB (default)
DYNAMODB_TABLE=office-tracker
AWS_REGION=eu-west-2

# Optional: set to http://localhost:8000 to use DynamoDB Local (docker-compose).
# DYNAMODB_ENDPOINT=

# Credentials — pick one of these approaches:
# (a) Direct keys
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# (b) Named profile from ~/.aws/credentials
# AWS_PROFILE=
